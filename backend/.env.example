# ==========================================
# Base de Datos PostgreSQL
# ==========================================
# ⚠️  NUNCA usar credenciales de ejemplo en producción
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/asistente_db
POSTGRES_PASSWORD=cambia-esta-clave-local

# ==========================================
# Configuración de la Aplicación
# ==========================================
APP_NAME=Asistente Integral API
APP_VERSION=1.0.0
ENVIRONMENT=development

# DEBUG: false en producción, true solo en desarrollo
DEBUG=false
SECRET_KEY=genera-una-clave-aleatoria-de-al-menos-32-caracteres
AUTO_CREATE_TABLES=true
SEED_DEMO_DATA=false

# ==========================================
# CORS - Origins permitidos
# ==========================================
# En desarrollo: http://localhost:3000,http://localhost:8080
# En producción: especificar solo los dominios reales
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# ==========================================
# IoT - API Keys para dispositivos ESP32
# ==========================================
# Formato: "key1:usuario_id1,key2:usuario_id2"
# Ejemplo: "esp32_sk_001:1,esp32_sk_002:2"
# ⚠️  En producción: guardar en BD con hash o vault seguro
IOT_API_KEYS=clave-unica-del-dispositivo:1

# ==========================================
# CompAI - Groq (solo backend)
# ==========================================
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Correo para recuperación de contraseña
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=CompAI <no-reply@tudominio.com>
SMTP_TLS=true

# Administración web (genera el hash con: python scripts/generate_admin_hash.py)
ADMIN_EMAIL=admin@tudominio.com
ADMIN_PASSWORD_HASH=
